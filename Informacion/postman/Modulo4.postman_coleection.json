{
  "info": {
    "name": "API Cursos Online - Módulo 4: Progreso",
    "description": "Colección completa de pruebas para el Módulo 4: Seguimiento de progreso del alumno (CUS-14), Tablero grupal (CUS-15) y Detalle individual (CUS-16).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Progreso de Lecciones (Alumno)",
      "item": [
        {
          "name": "1. Completar Lección",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/progreso/leccion/:idLeccion/completar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "progreso",
                "leccion",
                ":idLeccion",
                "completar"
              ],
              "variable": [
                {
                  "key": "idLeccion",
                  "value": "1",
                  "description": "ID de la lección a marcar como completada"
                }
              ]
            },
            "description": "Marca una lección como completada. Requiere ROL_ALUMNO y estar inscrito en el curso correspondiente. Es idempotente (enviar varias veces no duplica)."
          },
          "response": []
        },
        {
          "name": "2. Obtener Mi Progreso",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/progreso/mi-progreso",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "progreso",
                "mi-progreso"
              ]
            },
            "description": "Devuelve las estadísticas globales del alumno, agrupadas por curso y módulo."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Gestión y Tableros (Profesor)",
      "item": [
        {
          "name": "1. Obtener Tablero de Sección (CUS-15)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token_profesor}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/progreso/seccion/:idSeccion?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "progreso",
                "seccion",
                ":idSeccion"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ],
              "variable": [
                {
                  "key": "idSeccion",
                  "value": "1",
                  "description": "ID de la sección a consultar"
                }
              ]
            },
            "description": "Obtiene el tablero de avance grupal de una sección (CUS-15). Requiere ROL_PROFESOR y tener acceso al curso de la sección."
          },
          "response": []
        },
        {
          "name": "2. Obtener Detalle de Alumno (CUS-16)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token_profesor}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/progreso/alumno/:idAlumno/curso/:idCurso",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "progreso",
                "alumno",
                ":idAlumno",
                "curso",
                ":idCurso"
              ],
              "variable": [
                {
                  "key": "idAlumno",
                  "value": "12",
                  "description": "ID del alumno a consultar"
                },
                {
                  "key": "idCurso",
                  "value": "3",
                  "description": "ID del curso a consultar"
                }
              ]
            },
            "description": "Obtiene el detalle individual y el historial completo de un alumno en un curso específico (CUS-16). Requiere ROL_PROFESOR."
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "pega_tu_token_jwt_de_alumno_aqui",
      "type": "string"
    },
    {
      "key": "token_profesor",
      "value": "pega_tu_token_jwt_de_profesor_aqui",
      "type": "string"
    }
  ]
}