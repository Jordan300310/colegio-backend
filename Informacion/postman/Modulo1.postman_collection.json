            "body": {
              "mode": "raw",
              "raw": "{\n  \"contrasenaActual\": \"Admin$2026\",\n  \"nuevaContrasena\": \"Admin$2026\",\n  \"confirmarContrasena\": \"Admin$2026\"\n}"
            }
