                  "pm.collectionVariables.set('alumno_pwd_nueva', 'NuevaClave$2026');"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/auth/cambiar-contrasena",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_alumno}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contrasenaActual\": \"{{alumno_pwd}}\",\n  \"nuevaContrasena\": \"NuevaClave$2026\",\n  \"confirmarContrasena\": \"NuevaClave$2026\"\n}"
            }
          }
        },
