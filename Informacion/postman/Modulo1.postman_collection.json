            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"esto-no-es-un-correo\",\n  \"contrasena\": \"Admin$2026\"\n}"
            }
          }
        },
        {
          "name": "05 - Registrar alumno (pwd automática)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Tiene contrasenaTemporal', () => {",
                  "    const datos = pm.response.json().datos;",
                  "    pm.expect(datos.contrasenaTemporal).to.not.be.empty;",
                  "    pm.collectionVariables.set('alumno_correo', datos.correo);",
                  "    pm.collectionVariables.set('alumno_id', datos.idUsuario);",
                  "    pm.collectionVariables.set('alumno_pwd', datos.contrasenaTemporal);",
                  "    console.log('Alumno ID:', datos.idUsuario);",
                  "    console.log('Contraseña temporal:', datos.contrasenaTemporal);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/registrar",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Juan\",\n  \"apellidos\": \"Pérez\",\n  \"correo\": \"juan.perez@colegio.edu\",\n  \"codRol\": \"ROL_ALUMNO\",\n  \"contrasenaTemporal\": null\n}"
            }
          }
        },
        {
          "name": "06 - Registrar profesor (pwd manual)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const datos = pm.response.json().datos;",
                  "pm.collectionVariables.set('profesor_id', datos.idUsuario);",
                  "pm.collectionVariables.set('profesor_correo', datos.correo);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/registrar",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"María\",\n  \"apellidos\": \"López\",\n  \"correo\": \"maria.lopez@colegio.edu\",\n  \"codRol\": \"ROL_PROFESOR\",\n  \"contrasenaTemporal\": \"Profesor$2026\"\n}"
            }
          }
        },
