            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Otro\",\n  \"apellidos\": \"Usuario\",\n  \"correo\": \"juan.perez@colegio.edu\",\n  \"codRol\": \"ROL_ALUMNO\",\n  \"contrasenaTemporal\": null\n}"
            }
          }
        },
