          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"{{alumno_correo}}\",\n  \"contrasena\": \"{{alumno_pwd}}\"\n}"
            }
          }
        },
