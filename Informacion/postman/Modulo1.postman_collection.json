    {
      "name": "👥 Usuarios",
      "item": [
        {
          "name": "01 - Listar usuarios (página 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene content', () => {",
                  "    const datos = pm.response.json().datos;",
                  "    pm.expect(datos.content).to.be.an('array');",
                  "    pm.expect(datos.totalElements).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/usuarios?page=0&size=10&sort=desApellidos",
              "host": ["{{base_url}}"],
              "path": ["usuarios"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "desApellidos" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "02 - Listar usuarios — sin token (debe fallar)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
