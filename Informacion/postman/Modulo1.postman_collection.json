{
  "info": {
    "name": "Cursos Online — Auth & Usuarios",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔑 Auth",
      "item": [
        {
          "name": "01 - Login exitoso (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.exito && res.datos && res.datos.token) {",
                  "    pm.collectionVariables.set('token', res.datos.token);",
                  "    console.log('Token guardado:', res.datos.token);",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene token', () => pm.expect(res.datos.token).to.not.be.empty);",
                  "pm.test('exito es true', () => pm.expect(res.exito).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@colegio.edu\",\n  \"contrasena\": \"Admin$2026\"\n}"
            }
          }
        },
        {
          "name": "02 - Login credenciales incorrectas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('exito es false', () => pm.expect(pm.response.json().exito).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@colegio.edu\",\n  \"contrasena\": \"ClaveIncorrecta123\"\n}"
            }
          }
        },
        {
          "name": "03 - Login campo vacío",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('exito es false', () => pm.expect(pm.response.json().exito).to.be.false);"
                ]
              }
            }
