              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/cursos",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idNivel\": 1,\n  \"desNombre\": \"Java desde Cero\",\n  \"desDescripcion\": \"Curso introductorio al lenguaje Java.\"\n}"
            }
          }
