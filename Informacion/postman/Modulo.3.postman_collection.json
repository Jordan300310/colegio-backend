  "item": [
    {
      "name": "🎭 01 - Preparación de actores",
      "item": [
        {
          "name": "01 - Login como admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.exito && res.datos && res.datos.token) {",
                  "    pm.collectionVariables.set('tokenAdmin', res.datos.token);",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene token', () => pm.expect(res.datos.token).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@colegio.edu\",\n  \"contrasena\": \"<tu-contraseña-admin>\"\n}"
            }
          }
        },
        {
          "name": "02 - Crear el curso principal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "if(res.datos && res.datos.idCurso) {",
                  "    pm.collectionVariables.set('idCurso', res.datos.idCurso);",
                  "}"
